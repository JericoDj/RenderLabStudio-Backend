{
    "info": {
        "name": "💳 Payments",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Payments API — Create, Read, Update, Delete payments"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000"
        }
    ],
    "item": [
        {
            "name": "Create Payment",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/payments",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "payments"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"user\": \"USER_OBJECT_ID\",\n  \"plan\": \"PLAN_OBJECT_ID\",\n  \"amount\": 29.99,\n  \"currency\": \"USD\",\n  \"status\": \"pending\",\n  \"providerId\": \"stripe_pi_abc123\",\n  \"metadata\": {\n    \"source\": \"web\",\n    \"coupon\": \"SAVE10\"\n  }\n}"
                },
                "description": "Replace USER_OBJECT_ID and PLAN_OBJECT_ID with real MongoDB _id values."
            }
        },
        {
            "name": "Get All Payments",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/payments",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "payments"
                    ]
                }
            }
        },
        {
            "name": "Get Payment by ID",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/payments/:id",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "payments",
                        ":id"
                    ],
                    "variable": [
                        {
                            "key": "id",
                            "value": ""
                        }
                    ]
                },
                "description": "Replace :id with a real payment _id."
            }
        },
        {
            "name": "Update Payment",
            "request": {
                "method": "PUT",
                "url": {
                    "raw": "{{baseUrl}}/api/payments/:id",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "payments",
                        ":id"
                    ],
                    "variable": [
                        {
                            "key": "id",
                            "value": ""
                        }
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"status\": \"completed\"\n}"
                },
                "description": "Replace :id with a real payment _id."
            }
        },
        {
            "name": "Delete Payment",
            "request": {
                "method": "DELETE",
                "url": {
                    "raw": "{{baseUrl}}/api/payments/:id",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "payments",
                        ":id"
                    ],
                    "variable": [
                        {
                            "key": "id",
                            "value": ""
                        }
                    ]
                },
                "description": "Replace :id with a real payment _id."
            }
        }
    ]
}