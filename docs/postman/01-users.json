{
    "info": {
        "name": "👤 Users & Auth",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Users & Auth API — Register, Login, Google Login, OTP, Password Reset, CRUD"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000"
        }
    ],
    "item": [
        {
            "name": "Register User",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/users/register",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        "register"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"MySecurePass123\",\n  \"name\": \"Test User\"\n}"
                }
            }
        },
        {
            "name": "Login",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/users/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        "login"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"MySecurePass123\"\n}"
                }
            }
        },
        {
            "name": "Google Login",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/users/google-login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        "google-login"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"googleuser@gmail.com\",\n  \"googleId\": \"google-uid-abc123\",\n  \"name\": \"Google User\"\n}"
                }
            }
        },
        {
            "name": "Forgot Password (Send OTP)",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/users/forgot-password",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        "forgot-password"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
                }
            }
        },
        {
            "name": "Send OTP",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/users/send-otp",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        "send-otp"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
                }
            }
        },
        {
            "name": "Reset Password",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/users/reset-password",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        "reset-password"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewSecurePass456\"\n}"
                }
            }
        },
        {
            "name": "Get All Users",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/users",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users"
                    ]
                }
            }
        },
        {
            "name": "Get Current User",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/api/users/me",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        "me"
                    ]
                },
                "description": "Requires auth middleware (not yet implemented). Will return 500 until middleware sets req.user."
            }
        },
        {
            "name": "Create User",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{baseUrl}}/api/users",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users"
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Password123\",\n  \"name\": \"New User\"\n}"
                }
            }
        },
        {
            "name": "Update User",
            "request": {
                "method": "PUT",
                "url": {
                    "raw": "{{baseUrl}}/api/users/:id",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        ":id"
                    ],
                    "variable": [
                        {
                            "key": "id",
                            "value": ""
                        }
                    ]
                },
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Updated Name\"\n}"
                },
                "description": "Replace :id with a real user _id."
            }
        },
        {
            "name": "Delete User",
            "request": {
                "method": "DELETE",
                "url": {
                    "raw": "{{baseUrl}}/api/users/:id",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "users",
                        ":id"
                    ],
                    "variable": [
                        {
                            "key": "id",
                            "value": ""
                        }
                    ]
                },
                "description": "Replace :id with a real user _id."
            }
        }
    ]
}